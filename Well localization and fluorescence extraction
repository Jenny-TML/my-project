    img_filter = cv2.GaussianBlur(denoised_img, (3, 3), 0)
cv2.ADAPTIVE_THRESH_GAUSSIAN_C, cv2.THRESH_BINARY, 53, -5)
    img_adaptive = cv2.adaptiveThreshold(img_filter, 45535, cv2.ADAPTIVE_THRESH_GAUSSIAN_C, cv2.THRESH_BINARY, 93, -14)
    kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (4, 4))
    img_open = cv2.morphologyEx(img_adaptive, cv2.MORPH_OPEN, kernel) 
    kernel = cv2.getStructuringElement(cv2.MORPH_RECT, (19, 19))
    img_dilate = cv2.dilate(img_open, kernel, 9)
    img_adaptive1 = cv2.bitwise_and(img_adaptive, img_open)
cv2.WINDOW_KEEPRATIO)
    return img_adaptive1

def find_central(contour):
    M1 = cv2.moments(contour)
    cX = int(M1["m10"] / M1["m00"])
    cY = int(M1["m01"] / M1["m00"])
    return [cX, cY]

