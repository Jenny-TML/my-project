def combine_txt(path):
    files = glob.glob(path + '/*data.txt')
    image_num = [int(n.split('\\')[-1].split('data')[0]) for n in files]
    a = sorted(zip(files, image_num), key=lambda x: x[1])
    for index in range(len(a)):
        if index == 0:
            df_out = pd.read_csv(a[index][0], sep='\t')
            df_out['round'] = index + 1
        else:
            df_now = pd.read_csv(a[index][0], sep='\t')
            df_now['round'] = index + 1
            df_out = pd.concat([df_out, df_now], ignore_index=True)
    df_out.to_csv(path + '\data.csv', index=False)

