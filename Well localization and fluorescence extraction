def get_point_in_contour(img, contour):
    M1 = cv2.moments(contour)
    cX = int(M1["m10"] / M1["m00"])
    cY = int(M1["m01"] / M1["m00"])
    radius_sq = 9
    radius = int(np.sqrt(radius_sq)) + 1  
    y_min, y_max = max(0, cY - radius), min(img.shape[0], cY + radius)
    x_min, x_max = max(0, cX - radius), min(img.shape[1], cX + radius)
    y, x = np.ogrid[y_min:y_max, x_min:x_max]
    distance_sq = (x - cX) ** 2 + (y - cY) ** 2
    mask = distance_sq <= radius_sq
    points = img[y, x][mask]
    return points

def get_point_in_circle(img, center_x, center_y):
    radius_sq = 9
    radius = int(np.sqrt(radius_sq)) + 1  
    y_min, y_max = max(0, center_y - radius), min(img.shape[0], center_y + radius)
    x_min, x_max = max(0, center_x - radius), min(img.shape[1], center_x + radius)
    y, x = np.ogrid[y_min:y_max, x_min:x_max]
    distance_sq = (x - center_x)**2 + (y - center_y)**2
    mask = distance_sq <= radius_sq
    points = img[y, x][mask]
    return points

def sort_conts(conts):
    c_moments = [[cv2.moments(c)['m00'], cv2.moments(c)['m01'], cv2.moments(c)['m10']] for c in conts]
    position = [[int(m[2]/m[0]), int(m[1]/m[0])] for m in c_moments]
    a = sorted(zip(conts, position), key=lambda x: x[1][0]+x[1][1])  
    b = sorted(zip(conts, position), key=lambda x: -x[1][1]+x[1][0])  
    c = sorted(zip(conts, position), key=lambda x: x[1][1] - x[1][0]) 
    d = sorted(zip(conts, position), key=lambda x: -x[1][1] - x[1][0])  
    return a, b, c, d

